{
  "@context": {
    "@version": 1.1,
    "edc": "https://w3id.org/edc/v0.0.1/ns/",
    "dct": "http://purl.org/dc/terms/",
    "dcat": "http://www.w3.org/ns/dcat#",
    "QuerySpec": {
      "@id": "edc:QuerySpec",
      "@context": {
        "sortOrder": "edc:sortOrder",
        "sortField": "edc:sortField",
        "offset": "edc:offset",
        "limit": "edc:limit",
        "filterExpression": {
          "@id": "edc:filterExpression",
          "@container": "@set"
        }
      }
    },
    "Criterion": {
      "@id": "edc:Criterion",
      "@context": {
        "operandLeft": "edc:operandLeft",
        "operator": "edc:operator",
        "operandRight": "edc:operandRight"
      }
    },
    "inForceDate": "edc:inForceDate",
    "id": "edc:id",
    "description": "edc:description",
    "isCatalog": "edc:isCatalog",
    "conformsTo": {
      "@id": "dct:conformsTo",
      "@type": "@id"
    },
    "endpointURL": {
      "@id": "dcat:endpointURL",
      "@type": "@id"
    },
    "format": {
      "@id": "dct:format",
      "@type": "@id"
    }
  }
}